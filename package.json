{
  "name": "markdown-cms",
  "version": "1.0.0",
  "description": "A flat-file CMS powered by Markdown with YAML frontmatter",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "markdown-cms": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
